# easyResearchAssistant Configuration
# Copy to .env and configure. Never commit .env with real credentials.

# Security
ACCESS_TOKEN=your_secure_access_token_here
ADMIN_PASSWORD=your_admin_dashboard_password_here

# Provider Settings
SELECTION_STRATEGY=round_robin
MAX_RETRIES=3
REQUEST_TIMEOUT=60
COOLDOWN_MINUTES=30

# Cloudflare Nodes
CLOUDFLARE_ACCOUNT_1_ID=your_account_id_1
CLOUDFLARE_ACCOUNT_1_TOKEN=your_api_token_1
CLOUDFLARE_ACCOUNT_1_NAME=Provider-Alpha

CLOUDFLARE_ACCOUNT_2_ID=your_account_id_2
CLOUDFLARE_ACCOUNT_2_TOKEN=your_api_token_2
CLOUDFLARE_ACCOUNT_2_NAME=Provider-Beta

CLOUDFLARE_ACCOUNT_3_ID=your_account_id_3
CLOUDFLARE_ACCOUNT_3_TOKEN=your_api_token_3
CLOUDFLARE_ACCOUNT_3_NAME=Provider-Gamma

CLOUDFLARE_ACCOUNT_4_ID=your_account_id_4
CLOUDFLARE_ACCOUNT_4_TOKEN=your_api_token_4
CLOUDFLARE_ACCOUNT_4_NAME=Provider-Delta

CLOUDFLARE_ACCOUNT_5_ID=your_account_id_5
CLOUDFLARE_ACCOUNT_5_TOKEN=your_api_token_5
CLOUDFLARE_ACCOUNT_5_NAME=Provider-Epsilon

CLOUDFLARE_MODEL=@cf/meta/llama-3-8b-instruct

# Local Fallback (Ollama)
OLLAMA_ENABLED=true
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_MAX_TOKENS=1024

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
