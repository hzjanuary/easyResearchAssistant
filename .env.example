# easyResearchAssistant Configuration
# Copy this file to .env and fill in your values

# ===========================================
# SECURITY
# ===========================================
# Access password for API authentication (share with family only)
ACCESS_PASSWORD=your_family_secret_password_here

# ===========================================
# LOAD BALANCER SETTINGS
# ===========================================
# Rotation strategy: round_robin or random
ROTATION_STRATEGY=round_robin

# Maximum retry attempts when rate limited
MAX_RETRIES=3

# Request timeout in seconds
REQUEST_TIMEOUT=60

# Cloudflare AI Model (default: Llama 3 8B Instruct)
CLOUDFLARE_MODEL=@cf/meta/llama-3-8b-instruct

# ===========================================
# CLOUDFLARE ACCOUNTS
# ===========================================
# Add your Cloudflare accounts below (up to 10 supported)
# Get your account ID from: https://dash.cloudflare.com/ (right sidebar)
# Create API tokens at: https://dash.cloudflare.com/profile/api-tokens
# Token needs: Workers AI (Read) permission

# Account 1
CLOUDFLARE_ACCOUNT_1_ID=your_account_id_1
CLOUDFLARE_ACCOUNT_1_TOKEN=your_api_token_1
CLOUDFLARE_ACCOUNT_1_NAME=Family_Account_1

# Account 2
CLOUDFLARE_ACCOUNT_2_ID=your_account_id_2
CLOUDFLARE_ACCOUNT_2_TOKEN=your_api_token_2
CLOUDFLARE_ACCOUNT_2_NAME=Family_Account_2

# Account 3
CLOUDFLARE_ACCOUNT_3_ID=your_account_id_3
CLOUDFLARE_ACCOUNT_3_TOKEN=your_api_token_3
CLOUDFLARE_ACCOUNT_3_NAME=Family_Account_3

# Account 4
CLOUDFLARE_ACCOUNT_4_ID=your_account_id_4
CLOUDFLARE_ACCOUNT_4_TOKEN=your_api_token_4
CLOUDFLARE_ACCOUNT_4_NAME=Family_Account_4

# Account 5
CLOUDFLARE_ACCOUNT_5_ID=your_account_id_5
CLOUDFLARE_ACCOUNT_5_TOKEN=your_api_token_5
CLOUDFLARE_ACCOUNT_5_NAME=Family_Account_5
