# easyResearchAssistant Configuration
# =====================================
# Copy this file to .env and configure your settings
# IMPORTANT: Never commit .env with real credentials

# =============================================================================
# SECURITY (REQUIRED)
# =============================================================================
# Generate a secure token: python -c "import secrets; print(secrets.token_urlsafe(32))"
ACCESS_TOKEN=your_secure_access_token_here

# =============================================================================
# PROVIDER CONFIGURATION
# =============================================================================
# Selection Strategy: round_robin, random, or least_used
SELECTION_STRATEGY=round_robin

# Maximum retry attempts before fallback
MAX_RETRIES=3

# Request timeout in seconds
REQUEST_TIMEOUT=60

# =============================================================================
# CLOUDFLARE INFERENCE NODES
# =============================================================================
# Get your account ID: https://dash.cloudflare.com (right sidebar)
# Create API tokens: https://dash.cloudflare.com/profile/api-tokens
# Required permission: Workers AI (Read)

# Node 1 (Primary)
CLOUDFLARE_ACCOUNT_1_ID=your_account_id_1
CLOUDFLARE_ACCOUNT_1_TOKEN=your_api_token_1
CLOUDFLARE_ACCOUNT_1_NAME=Provider-Alpha

# Node 2
CLOUDFLARE_ACCOUNT_2_ID=your_account_id_2
CLOUDFLARE_ACCOUNT_2_TOKEN=your_api_token_2
CLOUDFLARE_ACCOUNT_2_NAME=Provider-Beta

# Node 3
CLOUDFLARE_ACCOUNT_3_ID=your_account_id_3
CLOUDFLARE_ACCOUNT_3_TOKEN=your_api_token_3
CLOUDFLARE_ACCOUNT_3_NAME=Provider-Gamma

# Node 4
CLOUDFLARE_ACCOUNT_4_ID=your_account_id_4
CLOUDFLARE_ACCOUNT_4_TOKEN=your_api_token_4
CLOUDFLARE_ACCOUNT_4_NAME=Provider-Delta

# Node 5
CLOUDFLARE_ACCOUNT_5_ID=your_account_id_5
CLOUDFLARE_ACCOUNT_5_TOKEN=your_api_token_5
CLOUDFLARE_ACCOUNT_5_NAME=Provider-Epsilon

# =============================================================================
# CLOUDFLARE MODEL CONFIGURATION
# =============================================================================
# Available models: https://developers.cloudflare.com/workers-ai/models/
CLOUDFLARE_MODEL=@cf/meta/llama-3-8b-instruct

# =============================================================================
# LOCAL FALLBACK (OLLAMA)
# =============================================================================
# Enable local GPU fallback for high availability
OLLAMA_ENABLED=true
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3

# Maximum tokens for local inference (conservative for 4GB VRAM)
OLLAMA_MAX_TOKENS=1024

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
HOST=0.0.0.0
PORT=8000
DEBUG=false
