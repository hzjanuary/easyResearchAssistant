# =============================================================================
# easyResearchAssistant Configuration Template
# =============================================================================
# Copy to .env and configure. Never commit .env with real credentials.
# Run: cp .env.template .env

# --- Security Configuration ---
# Generate a secure token: python -c "import secrets; print(secrets.token_urlsafe(32))"
ACCESS_TOKEN=your_secure_access_token_here
ADMIN_PASSWORD=your_admin_dashboard_password_here

# --- Networking & Docker Connectivity ---
# For Docker: services communicate via container names (e.g., http://backend:8000)
# For local development: use localhost
BACKEND_URL=http://localhost:8000
HOST=0.0.0.0
PORT=8000
DEBUG=false

# --- Centralized Logging ---
# Log file path (shared between backend and admin-ui via Docker volume)
LOG_FILE=system.log

# --- Inference Strategy ---
# Options: round_robin, random, least_used
SELECTION_STRATEGY=round_robin
MAX_RETRIES=3
REQUEST_TIMEOUT=60
COOLDOWN_MINUTES=30

# --- Research Mode (RAG) ---
# When enabled, performs real-time web search before LLM inference
# Number of search results to fetch (default: 3)
RAG_MAX_RESULTS=3

# --- Cloudflare Workers AI Nodes ---
# Add as many providers as needed (CLOUDFLARE_ACCOUNT_N_ID/TOKEN/NAME)
CLOUDFLARE_ACCOUNT_1_ID=your_account_id_1
CLOUDFLARE_ACCOUNT_1_TOKEN=your_api_token_1
CLOUDFLARE_ACCOUNT_1_NAME=Provider-Alpha

CLOUDFLARE_ACCOUNT_2_ID=your_account_id_2
CLOUDFLARE_ACCOUNT_2_TOKEN=your_api_token_2
CLOUDFLARE_ACCOUNT_2_NAME=Provider-Beta

# Optional: Add more providers for higher availability
# CLOUDFLARE_ACCOUNT_3_ID=your_account_id_3
# CLOUDFLARE_ACCOUNT_3_TOKEN=your_api_token_3
# CLOUDFLARE_ACCOUNT_3_NAME=Provider-Gamma

# Model selection - Llama 3.1 recommended for better accuracy & multilingual support
CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct

# --- Local Fallback (Ollama) ---
OLLAMA_ENABLED=true
# For Docker on Windows/Mac: use host.docker.internal to access host Ollama
# For Linux Docker: use 172.17.0.1 or configure network_mode: host
# For local development: use localhost
OLLAMA_ENDPOINT=http://localhost:11434
# Ensure you run 'ollama pull llama3.1' on your machine
OLLAMA_MODEL=llama3.1
OLLAMA_MAX_TOKENS=1024
